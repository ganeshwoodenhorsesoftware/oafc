{% elseif view_mode == 'listing' %}

  <div class="training-centre-listing-item">
    <div class="training-centre-listing-item__image">
      <a href="{{ url }}">
        {% if node.field_logo.entity.fileuri %}
          {%
            set logo_image = {
              '#theme':      'image_style',
              '#style_name': 'logo_listing',
              '#uri':        node.field_logo.entity.uri.value,
              '#alt':        node.field_logo.alt,
            }
          %}
          {{ logo_image }}
        {% else %}
          <img src="{{ base_path ~ directory }}/gfx/listing_placeholder.jpg" alt="{{ node.field_logo.alt }}" />
        {% endif %}
      </a>
    </div>
    <div class="training-centre-listing-item__title">
      <a href="{{ url }}">{{ node.title.value }}</a>
    </div>
    {% if content.field_address %}
      <div class="training-centre-listing-item__address">
        {{ content.field_address }}
      </div>
    {% endif %}
  </div>

  {#<div class="listing-item">#}
