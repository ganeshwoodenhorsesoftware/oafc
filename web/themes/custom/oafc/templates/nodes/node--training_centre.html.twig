{% else %}

  {%
  set classes = [
  'node',
  'node--type-' ~ node.bundle|clean_class,
  node.isPromoted() ? 'node--promoted',
  node.isSticky() ? 'node--sticky',
  not node.isPublished() ? 'node--unpublished',
  view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  'clearfix',
  ]
  %}

  <article{{ attributes.addClass(classes) }}>
    <div{{ content_attributes.addClass('node__content', 'clearfix') }}>
      <div class="row">
        <div class="col-md-5">
          {{ content.field_logo }}
        </div>
        <div class="col-md-7">
          <h3 class="node__title">{{ node.title.value }}</h3>
          {{ content.field_address }}
          {{ content.field_additional_information }}
        </div>
      </div>
      <div class="row">
        <div class="col-md-12">
          <p class="view-all-at-training-centre"><a href="{{ base_path }}education-training?f%5B0%5D=education_training_training_centres%3A{{ node.id }}">{{ 'View all courses available at this Training Centre >'|t }}</a></p>
          {{ content|without('field_logo','field_address','field_additional_information') }}
        </div>
      </div>
    </div>
  </article>

{% endif %}
