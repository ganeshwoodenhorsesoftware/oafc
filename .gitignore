# Valuables
auth.json
.env
.local
*.sql
*.sql.gz

# Ignore directories generated by Composer
/bin/
/drush/contrib/
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
!web/health.php
# Ignore Drupal's file directory
/private/
/private/*
/web/sites/*/files/

# Ignore SimpleTest multi-site environment.
/web/sites/simpletest/

# Additional libraries installed via composer.
# We should be having all libraries installed via composer and ignore the parent
# folder instead. Not doing this right now as we'd need some additional time for
# cleaning up.
web/libraries/jquery-ui-touch-punch

# Ignore local settings
web/sites/default/services.local.yml
web/sites/default/settings.local.php

# Ignore files generated by PhpStorm
/.idea/
/web/.idea/

# Ignore file generated by vscode
.vscode
xdebug.log

# Ignore Dev Container
.devcontainer

# Ignore .DS_Store files generated by macOS
*.DS_Store
config/sync/mailchimp.settings.yml
